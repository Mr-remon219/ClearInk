# =============================================================================
# ClearInk Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp data/environment/.env.sample data/environment/.env
#
# WARNING: .env contains secrets. It is git-ignored — never commit it.
#          This .env.sample file is a template and CAN be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Required — API Configuration
# -----------------------------------------------------------------------------

# Your Anthropic-compatible API key.
# For Anthropic:    https://console.anthropic.com/settings/keys
# For DeepSeek:     https://platform.deepseek.com/api_keys
ANTHROPIC_API_KEY = <your-api-key-here>

# Base URL of the Anthropic-compatible API endpoint.
# Anthropic (default):   https://api.anthropic.com
# DeepSeek:              https://api.deepseek.com/anthropic
ANTHROPIC_BASE_URL = https://api.anthropic.com

# Main agent model name.
# Anthropic examples:  claude-opus-4-1-20250805
#                      claude-sonnet-4-6-20250514
# DeepSeek example:    deepseek-v4-pro
MODEL = claude-opus-4-1-20250805

# -----------------------------------------------------------------------------
# Thinking / Reasoning Control
# -----------------------------------------------------------------------------

# Enable or disable extended thinking.
#   enabled  — the model will use extended thinking (recommended)
#   disabled — no extended thinking
THINKING_TYPE = enabled

# Thinking token budget (integer). 0 = no budget cap.
# Applies to Anthropic extended thinking. Ignored by DeepSeek.
THINKING_BUDGET = 0

# Thinking effort level (DeepSeek compatibility).
# Only forwarded when ANTHROPIC_BASE_URL contains "deepseek".
# Valid values: min, low, medium, high, max
THINKING_EFFORT = max

# -----------------------------------------------------------------------------
# Sub-Agent / Teammate Model
# -----------------------------------------------------------------------------

# Model used for sub-agents, teammates, and memory retrieval.
# A faster/cheaper model is recommended.
# Default (if unset): deepseek-v4-flash
SUBAGENT_MODEL = deepseek-v4-flash

# -----------------------------------------------------------------------------
# Advanced — Path Overrides
# -----------------------------------------------------------------------------

# Override the repository root directory.
# Useful when the Django backend runs from a different working directory
# or when deploying in a packaged environment.
# Default (if unset): auto-detected from this file's location
# CLEARINK_REPO_ROOT = /path/to/clearink

# Override the data directory for runtime state (.env, logs, memories, tasks,
# MCP config, teammate mailboxes).
# Default (if unset): <CLEARINK_REPO_ROOT>/data
# CLEARINK_DATA_DIR = /path/to/data
